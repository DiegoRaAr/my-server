pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  environment {
    IMAGE_NAME = 'diegoraar/home-frontend'
    APP_DIR = 'home-frontend'
    DOCKERHUB_CREDS = credentials('dockerhub-credentials')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build image') {
      steps {
        sh '''
          if [ -f Dockerfile ]; then
            docker build -t $IMAGE_NAME:latest -t $IMAGE_NAME:$BUILD_NUMBER .
          elif [ -f "$APP_DIR/Dockerfile" ]; then
            docker build -f "$APP_DIR/Dockerfile" -t $IMAGE_NAME:latest -t $IMAGE_NAME:$BUILD_NUMBER "$APP_DIR"
          else
            echo "No se encontró Dockerfile ni en raíz ni en $APP_DIR"
            exit 1
          fi
        '''
      }
    }

    stage('Push image') {
      steps {
        sh 'echo "$DOCKERHUB_CREDS_PSW" | docker login -u "$DOCKERHUB_CREDS_USR" --password-stdin'
        sh 'docker push $IMAGE_NAME:latest'
        sh 'docker push $IMAGE_NAME:$BUILD_NUMBER'
        sh 'docker logout'
      }
    }
  }

  post {
    always {
      sh 'docker image prune -f || true'
    }
  }
}
